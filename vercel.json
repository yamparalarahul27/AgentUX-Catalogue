{
  "buildCommand": "npm run build:site",
  "outputDirectory": "site",
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mockups.hirahul.xyz" }],
      "destination": "/api/prototype-proxy?path=$1"
    },
    { "source": "/designer/share", "destination": "/api/share-meta" },
    { "source": "/designer", "destination": "/designer/catalogue.html" },
    { "source": "/designer/(.*)", "destination": "/designer/catalogue.html" }
  ]
}
