{
  "name": "AgentUX Catalogue",
  "short_name": "AgentUX",
  "description": "Curated catalogue of crypto-app UX screens, grouped by family and flow.",
  "start_url": "/designer/",
  "scope": "/designer/",
  "display": "standalone",
  "background_color": "#1A1B26",
  "theme_color": "#1A1B26",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/designer/icon-192-v2.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/designer/icon-512-v2.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "/designer/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "images",
          "accept": ["image/*"]
        }
      ]
    }
  }
}
