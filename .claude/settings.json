{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/.env*)",
      "Write(**/.env*)",
      "Edit(**/.env*)",
      "Read(**/.dev.vars*)",
      "Write(**/.dev.vars*)",
      "Edit(**/.dev.vars*)",
      "Read(**/secrets/**)",
      "Write(**/secrets/**)",
      "Edit(**/secrets/**)",
      "Read(**/credentials/**)",
      "Write(**/credentials/**)",
      "Edit(**/credentials/**)",
      "Read(**/.vercel/**)",
      "Write(**/.vercel/**)",
      "Edit(**/.vercel/**)",
      "Read(**/serviceAccountKey*.json)",
      "Write(**/serviceAccountKey*.json)",
      "Edit(**/serviceAccountKey*.json)",
      "Read(**/firebase-adminsdk*.json)",
      "Write(**/firebase-adminsdk*.json)",
      "Edit(**/firebase-adminsdk*.json)",
      "Read(**/*.pem)",
      "Write(**/*.pem)",
      "Edit(**/*.pem)",
      "Read(**/*.key)",
      "Write(**/*.key)",
      "Edit(**/*.key)",
      "Read(**/.aws/**)",
      "Write(**/.aws/**)",
      "Edit(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Write(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "Read(**/id_rsa*)",
      "Write(**/id_rsa*)",
      "Edit(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Write(**/id_ed25519*)",
      "Edit(**/id_ed25519*)",
      "Read(**/.git-credentials)",
      "Write(**/.git-credentials)",
      "Edit(**/.git-credentials)",
      "Read(**/.netrc)",
      "Write(**/.netrc)",
      "Edit(**/.netrc)",
      "Read(**/.kube/**)",
      "Read(**/*.kubeconfig)",
      "Read(**/.docker/config.json)",
      "Read(**/.npmrc)",
      "Write(**/.npmrc)",
      "Edit(**/.npmrc)",
      "Read(**/.pypirc)",
      "Write(**/.pypirc)",
      "Edit(**/.pypirc)",
      "Read(**/.vault-token)",
      "Write(**/.vault-token)",
      "Edit(**/.vault-token)",
      "Read(**/*.tfstate*)",
      "Read(**/.terraform/**)",
      "Read(**/config/database.yml)",
      "Read(**/config/credentials.json)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/hooks/scan-secrets.js"
          }
        ]
      }
    ]
  }
}
